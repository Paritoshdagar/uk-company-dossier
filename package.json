{
  "name": "uk-company-dossier",
  "version": "0.1.0",
  "description": "A command-line service for reproducible UK company dossiers.",
  "private": false,
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=22 <23"
  },
  "files": [
    "NOTICE.md",
    "THIRD-PARTY-NOTICES.md",
    "bin/dossier.mjs",
    "dist",
    "schemas",
    "scripts/unavailable.mjs"
  ],
  "main": "./dist/cli/main.js",
  "types": "./dist/cli/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cli/main.d.ts",
      "import": "./dist/cli/main.js"
    },
    "./contracts/company-evidence": {
      "types": "./dist/contracts/company-evidence.d.ts",
      "import": "./dist/contracts/company-evidence.js"
    },
    "./contracts/errors": {
      "types": "./dist/contracts/errors.d.ts",
      "import": "./dist/contracts/errors.js"
    },
    "./package.json": "./package.json",
    "./schemas/VERSION": "./schemas/VERSION",
    "./schemas/company-evidence.schema.json": "./schemas/company-evidence.schema.json"
  },
  "bin": {
    "dossier": "./bin/dossier.mjs"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node scripts/build.mjs",
    "env:init": "node scripts/init-env.mjs",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format:check": "prettier --check THIRD-PARTY-NOTICES.md package.json tsconfig.json vitest.config.ts eslint.config.js bin/dossier.mjs \"scripts/**/*.mjs\" \"schemas/**/*.json\" \"src/**/*.ts\" \"tests/**/*.ts\" \"tests/fixtures/**/*.json\"",
    "doctor": "npm run cli -- doctor",
    "cli": "node --enable-source-maps dist/cli/main.js",
    "mcp": "npm run cli -- mcp",
    "examples:select": "npm run build --silent && node --enable-source-maps dist/examples/random-picker.js",
    "examples:ftse350": "npm run build --silent && node scripts/generate-ftse350-examples.mjs",
    "docs:mermaid": "node scripts/extract-mermaid.mjs",
    "docs:links": "node scripts/check-links.mjs",
    "verify:commit": "node scripts/verify-commit.mjs",
    "verify:push": "node scripts/verify-push.mjs",
    "verify:release": "node scripts/verify-release.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "commander": "15.0.0",
    "dotenv": "17.4.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.20.0",
    "@vitest/coverage-v8": "4.1.9",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "eslint": "10.5.0",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9"
  }
}
